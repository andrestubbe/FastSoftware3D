# Wavefront OBJ file for a Cube with UV coordinates
v -50.0 -50.0  50.0
v  50.0 -50.0  50.0
v  50.0  50.0  50.0
v -50.0  50.0  50.0
v -50.0 -50.0 -50.0
v  50.0 -50.0 -50.0
v  50.0  50.0 -50.0
v -50.0  50.0 -50.0

vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

# Front
f 1/1/ 2/2/ 3/3/ 4/4/
# Back
f 6/1/ 5/2/ 8/3/ 7/4/
# Top
f 4/1/ 3/2/ 7/3/ 8/4/
# Bottom
f 5/1/ 6/2/ 2/3/ 1/4/
# Left
f 5/1/ 1/2/ 4/3/ 8/4/
# Right
f 2/1/ 6/2/ 7/3/ 3/4/
